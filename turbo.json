{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "outputMode": "full"
    },
    "dev": { "cache": false, "persistent": true },
    "test": { "dependsOn": ["build"] }
  },
  "globalDependencies": ["tsconfig.json", "pnpm-lock.yaml"]
}
