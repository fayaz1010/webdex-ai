# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://webdex:webdex@localhost:5432/webdex
DATABASE_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Local Model ───────────────────────────────────────────
# Default: Qwen2.5-14B-Instruct-Q8_0 (~15.7 GB)
# Sized for Oracle A1 Flex free tier (24 GB RAM, 4 OCPUs ARM Ampere):
#   weights=15.7GB + KV-cache=1.3GB + OS/Node/DB=3.0GB + headroom=4.0GB = 24GB
# Download: bash scripts/download-models.sh
LOCAL_MODEL_PATH=./models/qwen2.5-14b-instruct-q8_0.gguf
# CPU threads to use for inference (default: all cores minus 1)
LLM_THREADS=7
# Context window in tokens (default: 8192, adjust down if RAM is tight)
LLM_CONTEXT_SIZE=8192
# Embedding model — downloaded automatically on first run
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ── Free API Inference Cascade ────────────────────────────
# Tried in order before paying for Claude. Get free keys at:
#   Groq:       https://console.groq.com      (14,400 req/day, Llama 3.3 70B)
#   Gemini:     https://aistudio.google.com   (15 RPM / 1M TPM free, Flash)
#   OpenRouter: https://openrouter.ai         (free models: llama-3.1-8b)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Anthropic Claude (paid final fallback) ────────────────
ESCALATION_API_KEY=sk-ant-api03-YOUR_KEY_HERE
ESCALATION_MODEL=claude-3-5-sonnet-20241022

# ── CAPTCHA Solving (optional) ────────────────────────────
# If set, WebDex will attempt to solve reCAPTCHA/hCaptcha via 2captcha API.
# Get a key at: https://2captcha.com  (compatible with CapSolver too)
# Leave blank to skip CAPTCHA solving (pages will be flagged but not solved).
CAPTCHA_API_KEY=
CAPTCHA_SERVICE_URL=https://2captcha.com

# ── Crawler ───────────────────────────────────────────────
CRAWL_CONCURRENCY=3
CRAWL_DEFAULT_DELAY_MS=1500
CRAWL_MAX_ATTEMPTS=5
PLAYWRIGHT_HEADLESS=true

# ── API Server ────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
# Secret used to sign JWT tokens (generate: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_hex_string
# Salt for hashing API keys (generate: openssl rand -hex 16)
API_KEY_SALT=change_me_to_another_random_hex
# Internal API key for MCP server to call the API server
INTERNAL_API_KEY=change_me_internal_key

# ── MCP Server ────────────────────────────────────────────
MCP_SERVER_PORT=3001

# ── Dashboard (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
