{
  "name": "@webdex/database",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');const s=p.join('src','schema','migrations');const d=p.join('dist','schema','migrations');fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@webdex/shared": "workspace:*",
    "pg": "^8.11.0",
    "pgvector": "^0.1.8"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/pg": "^8.11.0",
    "@types/node": "^20.0.0"
  }
}
