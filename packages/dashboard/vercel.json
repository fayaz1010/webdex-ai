{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm turbo build --filter=@webdex/dashboard",
  "outputDirectory": "packages/dashboard/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://webdex-api.up.railway.app/:path*"
    }
  ]
}
