{
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && ./node_modules/.bin/turbo build --filter=@webdex/dashboard",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://webdex-api.up.railway.app/:path*"
    }
  ]
}
