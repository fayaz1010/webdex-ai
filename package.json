{
  "name": "webdex-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "crawl": "pnpm --filter @webdex/crawler crawl",
    "interpret": "pnpm --filter @webdex/interpreter interpret",
    "worker": "pnpm --filter @webdex/interpreter worker",
    "migrate": "pnpm --filter @webdex/database migrate",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
